# === Arc Cashier Configuration ===
# Copy this file to .env and configure your variables

# ---------------------------------------------------------
# Required Configuration
# ---------------------------------------------------------

# Your wallet address where streaming payments are received.
# Example: 0x1234567890abcdef1234567890abcdef12345678
SELLER_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Your private key is required to check your balance and withdraw your earnings
# from the Circle Gateway via the /seller/balance and /seller/withdraw endpoints.
# Keep this STRICTLY PRIVATE. Do not commit your .env file!
# Example: 0xabc123...
SELLER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ---------------------------------------------------------
# Circle User-Controlled Wallets (Required)
# Both values come from the Circle Developer Console:
# https://console.circle.com → Apps → Your App
# ---------------------------------------------------------

# Backend API key — authenticates all server-side calls to Circle's API
# (create users, session tokens, wallets, and transactions)
CIRCLE_API_KEY=TEST_API_KEY:YOUR_KEY_HERE

# Frontend App ID — sent to the browser so W3SSdk can initialize the
# Circle-hosted Email/PIN UI for wallet creation and transaction signing
CIRCLE_APP_ID=your_app_id_here

# The x402 Gateway contract address that holds viewer escrow funds.
# Deposit transactions from user SCA wallets are sent to this address.
# For Arc Testnet, the official GatewayWallet address is:
GATEWAY_DEPOSIT_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9

# ---------------------------------------------------------
# Optional Configuration
# ---------------------------------------------------------

# Server port (default: 3000)
# PORT=3000

# PeerTube Webhook Secret (used to verify signed webhooks from the PeerTube plugin)
# PEERTUBE_WEBHOOK_SECRET=your_generated_secret_here

# Public URL where the sidecar API is accessible.
# Required for production (e.g. https://api.mycashier.com)
# Defaults to http://localhost:3000 if not set.
# PUBLIC_URL=http://localhost:3000

# Minimum balance the ephemeral wallet must hold to initiate a session
# MIN_WALLET_BALANCE=0.01
