# === Tessera Configuration ===
# Copy this file to .env and configure your variables

# ---------------------------------------------------------
# Circle User-Controlled Wallets (Required)
# If you don't know how to get these, follow the guides:
# - API Key: docs/tutorials/circle-api-key.md
# - App ID: docs/tutorials/circle-app-id.md
# ---------------------------------------------------------
CIRCLE_API_KEY=TEST_API_KEY:YOUR_KEY_HERE
CIRCLE_APP_ID=your_app_id_here

# ---------------------------------------------------------
# Security Configuration
# ---------------------------------------------------------
# High-entropy secret key used to encrypt ephemeral session keys at rest.
# Must be a secure random string (e.g. 32+ characters).
MASTER_KEY=your_secure_master_key_here

# ---------------------------------------------------------
# Arc Testnet RPC Node (Optional — Defaults to https://rpc.testnet.arc.network)
# ---------------------------------------------------------
# The RPC endpoint for Arc Testnet. You can use the official public endpoint,
# or supply a custom endpoint URL from Canteen, QuickNode, dRPC, or Alchemy.
# ARC_RPC_URL=https://rpc.testnet.arc.network
# ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/your-api-key
# ARC_RPC_URL=https://your-node.arc-testnet.quiknode.pro/your-api-key/
ARC_RPC_URL=https://rpc.testnet.arc.network


# ---------------------------------------------------------
# Platform Wallet Configuration (Required)
# ---------------------------------------------------------
# Platform EVM address (configured dynamically via PeerTube settings UI,
# but can be set here as a fallback)
# TESSERA_ADMIN_WALLET=0xYourEVMAddressHere

# Webhook secret to verify PeerTube plugin signatures (Generated automatically during setup)
# PEERTUBE_WEBHOOK_SECRET=your_generated_secret_here

# Public URL for the sidecar API (Defaults to http://localhost:7878)
PUBLIC_URL=http://localhost:7878

# Server port (Defaults to 7878)
PORT=7878

# Minimum balance the ephemeral wallet must hold to initiate a session
# MIN_WALLET_BALANCE=0.01

# The amount of USDC reserved for gas during withdrawal settlement on Arc Testnet (Defaults to 0.01)
# RETAINED_GAS_AMOUNT=0.01
