    "@circle-fin/x402-batching": "^3.0.4",
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "@x402/express": "^2.14.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "http-proxy-middleware": "^4.0.0",
    "viem": "^2.52.0"
